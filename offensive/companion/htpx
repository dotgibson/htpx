#!/usr/bin/env bash
# offensive/companion/htpx — fuzzy browser over the structured red/blue companion.
# ──────────────────────────────────────────────────────────────────────────────
# MVP proof for the ATT&CK-tagged, red<->blue-paired pentest companion: search an
# attack, preview it ALONGSIDE its paired blue detection, fill the {{slots}} from
# the engagement env, and copy the command(s) to the clipboard.
#
#   htpx                 # pick an attack; fills {{slots}} from $RHOST/$LHOST/... and copies
#   htpx --preview FILE  # internal: render an entry + its paired detection (fzf preview)
#
# Slots are filled from these env vars (unset slots are left literal + flagged):
#   {{rhost}}=$RHOST  {{lhost}}=$LHOST  {{domain}}=$DOMAIN  {{user}}=$USER_T
#   {{password}}=$PASS  {{hostname}}=$HOSTNAME_T  {{nthash}}=$NTHASH
#   {{port}}=$PORT  {{share}}=$SHARE
# Deps: fzf (required); bat (nicer preview, falls back to cat); clip (Core helper,
# falls back to stdout). Frontmatter is parsed with sed — no yq needed.
# ──────────────────────────────────────────────────────────────────────────────
set -euo pipefail
# bash 5.2's patsub_replacement makes a literal `&` in a ${var//pat/repl} replacement
# expand to the matched text — which would corrupt a password/hash slot value that
# contains `&`. Turn it off so replacements are literal (no-op on older bash).
shopt -u patsub_replacement 2>/dev/null || true

HERE="$(cd -- "$(dirname -- "${BASH_SOURCE[0]:-$0}")" && pwd)"
ENTRIES="$HERE/entries"

# Read a scalar field from ONLY the YAML frontmatter (the first --- … --- block),
# so a `pair:`/`title:` that appears later in the body (an example, a note) can't be
# picked up by mistake.
_field() {
  awk -v k="$2" '
    /^---[[:space:]]*$/ { n++; next }
    n >= 2 { exit }
    n == 1 && index($0, k ":") == 1 { sub("^" k ":[[:space:]]*", ""); print; exit }
  ' "$1"
}

# Render a file with bat if present, else cat (bat may be batcat on Debian/Kali).
_render() {
  if command -v bat >/dev/null 2>&1; then bat --color=always --style=plain -- "$1"
  elif command -v batcat >/dev/null 2>&1; then batcat --color=always --style=plain -- "$1"
  else cat -- "$1"; fi
}

# ── internal: fzf preview — show the red entry, then its paired blue detection ──
if [[ "${1:-}" == "--preview" ]]; then
  file="${2:?--preview needs a file}"
  _render "$file"
  pair="$(_field "$file" pair)"
  if [[ -n "$pair" && "$pair" != "null" ]]; then
    # the pair id lives in the OTHER colour's dir; find it without assuming which.
    mate="$(grep -rl "^id:[[:space:]]*$pair\$" "$ENTRIES" 2>/dev/null | head -n1)"
    if [[ -n "$mate" ]]; then
      printf '\n\033[1;34m── paired detection ─────────────────────────\033[0m\n'
      _render "$mate"
    fi
  fi
  exit 0
fi

command -v fzf >/dev/null 2>&1 || { echo "htpx: needs fzf" >&2; exit 1; }

# ── pick an attack (red entries), previewing it + its detection ────────────────
sel="$(
  while IFS= read -r f; do
    printf '%s\t%s\n' "$(_field "$f" title)" "$f"
  done < <(find "$ENTRIES/red" -name '*.md' | sort) |
    fzf --with-nth=1 --delimiter=$'\t' --prompt='attack ❯ ' \
        --preview="$0 --preview {2}" --preview-window=right,62%
)"
[[ -n "$sel" ]] || exit 0
file="${sel#*$'\t'}"

# ── fill {{slots}} from the engagement env (unset → left literal, then flagged) ─
# Guarded bash string-replacement, NOT sed: a `}` inside a `${VAR:-{{slot}}}`
# default prematurely closes the expansion, and sed would choke on a `/` or `&`
# in a password. `${s//'{{slot}}'/$VAR}` is literal on both sides.
fill() { # stdin -> stdout, substituting {{slot}} from the named env var when set
  local s
  s="$(cat)"
  [[ -n "${RHOST:-}" ]] && s="${s//'{{rhost}}'/$RHOST}"
  [[ -n "${LHOST:-}" ]] && s="${s//'{{lhost}}'/$LHOST}"
  [[ -n "${DOMAIN:-}" ]] && s="${s//'{{domain}}'/$DOMAIN}"
  [[ -n "${USER_T:-}" ]] && s="${s//'{{user}}'/$USER_T}"
  [[ -n "${PASS:-}" ]] && s="${s//'{{password}}'/$PASS}"
  [[ -n "${HOSTNAME_T:-}" ]] && s="${s//'{{hostname}}'/$HOSTNAME_T}"
  [[ -n "${NTHASH:-}" ]] && s="${s//'{{nthash}}'/$NTHASH}"
  [[ -n "${PORT:-}" ]] && s="${s//'{{port}}'/$PORT}"
  [[ -n "${SHARE:-}" ]] && s="${s//'{{share}}'/$SHARE}"
  printf '%s' "$s"
}

# extract the fenced command block(s) from the entry body, then fill slots
cmd="$(awk '/^```/{f=!f; next} f' "$file" | fill)"

# Flag any unfilled slots FIRST — before the copy + "copied" line — so a half-filled
# command isn't pasted blind under a success message.
if printf '%s' "$cmd" | grep -oq '{{[a-z_]*}}'; then
  # shellcheck disable=SC2016  # $RHOST/$LHOST here are literal advice text, not expansions
  printf '\033[33munfilled:\033[0m %s  (export $RHOST/$LHOST/... and re-run)\n' \
    "$(printf '%s' "$cmd" | grep -o '{{[a-z_]*}}' | sort -u | tr '\n' ' ')" >&2
fi

if command -v clip >/dev/null 2>&1; then
  printf '%s' "$cmd" | clip
  printf '%s\n\n\033[2mcopied to clipboard\033[0m\n' "$cmd" >&2
else
  printf '%s\n' "$cmd"
fi
