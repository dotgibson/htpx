Credential cracking — hashcat / john
++++++++++++++++++++++++++++++++++++++++
# Hashing is ONE-WAY — you crack it, you don't decrypt it. (Encoding like base64 is
# reversible with no key; encryption needs a key; hashes give up only to guessing.)
hashid '<hash>'          # or name-that-hash — identify the mode before you burn GPU
# Modes you actually meet (where they come from):
#   1000  NTLM (NTDS dump)            3000  LM
#   5500  NetNTLMv1 (Responder)       5600  NetNTLMv2 (Responder)
#   13100 Kerberoast (TGS)            18200 AS-REP (krb5asrep)
#   2100  DCC2 / MSCache2 (cached)    3200  bcrypt
#   full table: hashcat.net/wiki/doku.php?id=example_hashes

# Attack modes (-O = optimized kernel, big speedup; mind the password-length cap):
hashcat -m 1000 -O hashes.txt /usr/share/wordlists/rockyou.txt              # -a 0 dictionary
hashcat -m 13100 -O kerb.txt /usr/share/wordlists/rockyou.txt -r /usr/share/hashcat/rules/best64.rule  # dict + RULES
hashcat -m 1000 -O hashes.txt -a 3 ?u?l?l?l?l?l?d?d                         # -a 3 mask / brute
hashcat -m 5500 -O hashes.txt -a 6 wordlist.txt ?d?d?d?d                    # -a 6 hybrid word+mask
# Rules mutate the wordlist (apple -> @ppl3 / apple123 / app); stack them for more reach:
#   best64.rule (fast)   OneRuleToRuleThemAll   NSAKEY/nsa-rules   nyxgeek-rules

# Build TARGETED wordlists — beats raw rockyou on corporate passwords:
exrex "(Winter|Spring|Summer|Fall|Autumn)20(1[7-9]|2[0-5])" > seasons.txt    # Season+Year
cupp -i                                                                       # OSINT-driven (names/dates/pets)
kwp basechars/full.base keymaps/en-us.keymap routes/2-to-10-max-3-direction-changes.route > kwalks.txt
# PACK: profile a REAL dump's masks, then crack within this org's actual policy:
statsgen ntds.txt -o org.masks && maskgen org.masks --optindex -o org.hcmask
hashcat -m 1000 -O ntds.txt -a 3 org.hcmask
# hate_crack chains dict -> rules -> mask automatically over a hash file.

# Capture hygiene: dedupe Responder hashes to one per user before cracking:
sort -u -t: -k1,1 responder.hashes > unique.hashes
# Kerberoast triage — which cracked SPN users are actually privileged?
cut -d'$' -f4 spns.txt | cut -d'*' -f2 > spn_users.txt
grep -wi -f spn_users.txt group-membership.txt | grep -i 'admin\|vpn\|server'
# Best real-world list: ICANN zone files (CZDS) -> domain labels. Enormous, but gold.
////////////////////////////////////////


