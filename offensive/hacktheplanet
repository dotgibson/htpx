# ProjectDiscovery stack (install/update via pdtm): subfinder -> httpx -> nuclei
subfinder -d <domain> -silent | httpx -ip -asn -title -tech-detect -server -status-code
nuclei -u <domain> -t dns
# Google dorking (exploit-db.com/google-hacking-database):
#   site:<domain> "internal use only"   site:<domain> filetype:xls   site:<domain> password
#   site:<domain> inurl:"index of"      site:<domain> login|portal|admin|upload
# Names/emails -> usernames: hunter.io, dehashed.com, WeakestLink (LinkedIn scrape).

