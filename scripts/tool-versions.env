# scripts/tool-versions.env — SINGLE SOURCE for the pinned dev-tool versions.
# ──────────────────────────────────────────────────────────────────────────────
# These versions were duplicated across .github/workflows/ci.yml (the `env:` block)
# and .pre-commit-config.yaml (`rev:` fields) with nothing keeping them in step.
# This file is now canonical and read by all three consumers:
#   • .github/workflows/ci.yml — a "Load pinned tool versions" step cats this into
#     $GITHUB_ENV, so CI installs exactly these (no version literals left in ci.yml).
#   • scripts/setup.sh (`make setup`) — local hermetic bootstrap installs/audits to
#     these same versions, so a contributor's box matches CI.
#   • scripts/audit-core.sh — a version-consistency section asserts the .pre-commit
#     hook revs still equal these (pre-commit YAML can't read this file dynamically,
#     so it's gated instead — drift fails the audit). A second section asserts every
#     pinned *_VERSION below has a matching 64-hex *_SHA256 (see the checksum block).
#   • .github/actions/setup-core-tools — the shared composite action that downloads
#     the gate binaries reads BOTH the *_VERSION and the *_SHA256 from $GITHUB_ENV
#     and verifies each download before installing.
#
# Bump a version HERE and it propagates (ci + setup) or is enforced (pre-commit);
# then run `scripts/update-tool-checksums.sh` to refresh the matching *_SHA256.
# Plain KEY=VALUE, no spaces around `=`, no `v` prefix — so this both `source`s in
# bash AND appends straight to $GITHUB_ENV.
# ──────────────────────────────────────────────────────────────────────────────
SHELLCHECK_VERSION=0.10.0
LUACHECK_VERSION=1.2.0
NVIM_VERSION=0.12.3
MARKDOWNLINT_VERSION=0.22.1
ACTIONLINT_VERSION=1.7.8
GITLEAKS_VERSION=8.30.1
# shfmt is pinned here for the setup-core-tools action's OS-repo consumers (MacBook
# + the distro/role lint workflows). Core's OWN audit deliberately does not gate
# shfmt — this pin exists so the shared action has one verified shfmt to install.
SHFMT_VERSION=3.8.0
PRECOMMIT_VERSION=4.0.1
PRECOMMIT_HOOKS_VERSION=5.0.0
# Claude Code CLI for the scheduled maintenance bots (.github/workflows/claude-routines.yml).
# Pinned like every other tool here (the workflow installs this exact version); bump deliberately.
CLAUDE_CODE_VERSION=2.1.185

# ── SHA-256 of the release ASSETS the setup-core-tools composite action downloads
# (Linux x86_64). This is the real supply-chain control: the action verifies each
# download against the pin here before installing, so a tampered or MITM'd asset
# fails the build instead of executing in the gate. One hash per downloaded tool;
# `scripts/update-tool-checksums.sh` recomputes them and the audit fails any pinned
# version that lacks a 64-hex hash. (luacheck = luarocks build, markdownlint/
# pre-commit/claude = npm/pip/registry installs — not raw downloads, so no hash.)
SHELLCHECK_SHA256=6c881ab0698e4e6ea235245f22832860544f17ba386442fe7e9d629f8cbedf87
ACTIONLINT_SHA256=be92c2652ab7b6d08425428797ceabeb16e31a781c07bc388456b4e592f3e36a
GITLEAKS_SHA256=551f6fc83ea457d62a0d98237cbad105af8d557003051f41f3e7ca7b3f2470eb
NVIM_SHA256=c441b547142860bf01bcce39e36cbed185c41112813e15443b16e5237750724d
SHFMT_SHA256=27b3c6f9d9592fc5b4856c341d1ff2c88856709b9e76469313642a1d7b558fe0
