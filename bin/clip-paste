#!/usr/bin/env bash
# core/bin/clip-paste — cross-OS "paste from clipboard" to stdout.
# Mirror of `clip`. Detection order: WSL -> macOS -> Wayland -> X11.
set -euo pipefail

if [[ -n "${WSL_DISTRO_NAME:-}" ]] || grep -qiE 'microsoft|wsl' /proc/version 2>/dev/null; then
  # strip the CRs that the Windows clipboard appends
  powershell.exe -NoProfile -Command Get-Clipboard 2>/dev/null | tr -d '\r'
elif [[ "$(uname -s)" == "Darwin" ]]; then
  exec pbpaste
elif [[ -n "${WAYLAND_DISPLAY:-}" ]] && command -v wl-paste >/dev/null; then
  exec wl-paste --no-newline
elif command -v xclip >/dev/null; then
  exec xclip -selection clipboard -o
elif command -v xsel >/dev/null; then
  exec xsel --clipboard --output
else
  echo "clip-paste: no clipboard backend found (install wl-clipboard or xclip)" >&2
  exit 1
fi
