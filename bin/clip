#!/usr/bin/env bash
# core/bin/clip — cross-OS "copy to clipboard". Reads stdin, copies it.
# ONE clipboard implementation, shared by zsh (pbcopy), tmux (copy-pipe), and
# nvim (clipboard provider). Detection order: WSL -> macOS -> Wayland -> X11.
set -euo pipefail

# Hot path: nvim/tmux re-exec this on EVERY yank/paste (the clipboard provider runs
# with cache_enabled=0 by design — see nvim clipboard.lua). So the WSL probe reads
# /proc/version with the `$(<file)` bash builtin + a glob match instead of forking a
# `grep` per invocation — on ordinary (non-WSL) Linux that grep ran every single time.
# nocasematch makes the glob case-insensitive; CLIP_PROC_VERSION lets the test suite
# point the probe at a fixture instead of the host's real /proc/version (hermetic).
shopt -s nocasematch
_pv=""
[[ -z "${WSL_DISTRO_NAME:-}" && -r "${CLIP_PROC_VERSION:-/proc/version}" ]] && _pv="$(<"${CLIP_PROC_VERSION:-/proc/version}")"
if [[ -n "${WSL_DISTRO_NAME:-}" || "$_pv" == *microsoft* || "$_pv" == *wsl* ]]; then
  exec clip.exe # WSL -> Windows clipboard
elif [[ "$(uname -s)" == "Darwin" ]]; then
  exec pbcopy # macOS native
elif [[ -n "${WAYLAND_DISPLAY:-}" ]] && command -v wl-copy >/dev/null; then
  exec wl-copy # Wayland
elif command -v xclip >/dev/null; then
  exec xclip -selection clipboard # X11
elif command -v xsel >/dev/null; then
  exec xsel --clipboard --input # X11 fallback
else
  echo "clip: no clipboard backend found (install wl-clipboard or xclip)" >&2
  exit 1
fi
