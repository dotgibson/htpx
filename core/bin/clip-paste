#!/usr/bin/env bash
# core/bin/clip-paste — cross-OS "paste from clipboard" to stdout.
# Mirror of `clip`. Detection order: WSL -> macOS -> Wayland -> X11.
set -euo pipefail
# Same hot-path WSL probe as `clip`: a fork-free `$(<file)` read of /proc/version
# (overridable via CLIP_PROC_VERSION for the tests) instead of a per-invocation grep.
shopt -s nocasematch
_pv=""
[[ -z "${WSL_DISTRO_NAME:-}" && -r "${CLIP_PROC_VERSION:-/proc/version}" ]] && _pv="$(<"${CLIP_PROC_VERSION:-/proc/version}")"
if [[ -n "${WSL_DISTRO_NAME:-}" || "$_pv" == *microsoft* || "$_pv" == *wsl* ]]; then
  # strip the CRs that the Windows clipboard appends.
  # NB: this is script scope, not a function — `local`/`return` are illegal here
  # and would abort under `set -e`, breaking paste on WSL. Use a plain var + exit.
  out="$(powershell.exe -NoProfile -Command Get-Clipboard 2>/dev/null)" || exit 1
  printf '%s' "$out" | tr -d '\r'
elif [[ "$(uname -s)" == "Darwin" ]]; then
  exec pbpaste
elif [[ -n "${WAYLAND_DISPLAY:-}" ]] && command -v wl-paste >/dev/null; then
  exec wl-paste --no-newline
elif command -v xclip >/dev/null; then
  exec xclip -selection clipboard -o
elif command -v xsel >/dev/null; then
  exec xsel --clipboard --output
else
  echo "clip-paste: no clipboard backend found (install wl-clipboard or xclip)" >&2
  exit 1
fi
