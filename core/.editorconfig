# .editorconfig — house style for dotfiles-core.
# https://editorconfig.org  — honored natively by Neovim (this repo's editor),
# VS Code, and most others. This file is the single enforcer of indentation in
# the multi-language tree (bash, zsh, lua, toml, yaml): it keeps everything on one
# consistent 2-space style at edit time. NB: neither shfmt nor stylua is wired
# into CI or pre-commit (shfmt would expand the deliberate compact one-liner
# style — see scripts/audit-core.sh); the enforced checks are shellcheck + luacheck
# (real bugs) plus the behavioral/manifest audit. Formatting stays editorconfig.
root = true
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
# Shell — 2-space (shfmt is intentionally NOT enforced; this just keeps edits 2-space).
[*.{sh,zsh}]
indent_size = 2
# Lua (Neovim config) — 2-space; luacheck (run from nvim/) is the enforced linter.
[*.lua]
indent_size = 2
[*.{toml,yml,yaml}]
indent_size = 2
# Markdown: trailing whitespace can be a meaningful hard line break.
[*.md]
trim_trailing_whitespace = false
# tmux/git configs follow upstream conventions.
[*.{conf,gitconfig}]
indent_size = 2
# Makefile — recipe lines REQUIRE real tabs; override the global space rule.
[Makefile]
indent_style = tab
