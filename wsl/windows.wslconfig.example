# dotfiles-Kali/wsl/windows.wslconfig.example
# =============================================================================
# This file goes on the WINDOWS side, NOT inside Kali. Copy it to:
#     %UserProfile%\.wslconfig      (e.g. C:\Users\<you>\.wslconfig)
# then run  wsl.exe --shutdown  and reopen Kali.
#
# WHY THIS MATTERS FOR OFFENSIVE WORK:
# By default WSL2 sits behind a NAT, so a listener you start in Kali
# (reverse shell, msf handler, responder, an http server for file transfer)
# is NOT reachable from other hosts on your LAN — they'd hit the Windows host,
# not your Kali VM. `networkingMode=mirrored` makes Kali share the Windows
# host's network interfaces, so your listeners are directly reachable and your
# Kali IP matches the host's. Requires Windows 11 22H2 or newer.
# =============================================================================

[wsl2]
networkingMode=mirrored
dnsTunneling=true
firewall=true
autoProxy=true

# Optional resource caps — uncomment/tune to taste:
# memory=8GB
# processors=4

[experimental]
# Reclaim freed memory back to Windows over time.
autoMemoryReclaim=gradual
