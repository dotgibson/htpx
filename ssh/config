# dotfiles-Kali/ssh/config  ->  ~/.ssh/config   (symlinked, mode 600)
# Hardened defaults + connection multiplexing. Host-specific secrets and real
# hostnames do NOT belong here — keep those in ~/.ssh/config.local (untracked)
# and they'll be picked up by the Include below.

Include ~/.ssh/config.local

Host *
    AddKeysToAgent yes
    HashKnownHosts yes
    ServerAliveInterval 60
    ServerAliveCountMax 3
    # connection reuse — faster repeat logins
    ControlMaster auto
    ControlPath ~/.ssh/sockets/%r@%h-%p
    ControlPersist 600
    # modern crypto only
    KexAlgorithms curve25519-sha256,curve25519-sha256@libssh.org,diffie-hellman-group16-sha512
    Ciphers chacha20-poly1305@openssh.com,aes256-gcm@openssh.com,aes128-gcm@openssh.com
    MACs hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com

Host github.com
    User git
    IdentitiesOnly yes
    # IdentityFile ~/.ssh/id_ed25519

