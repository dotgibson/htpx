# dotfiles-Kali/.gitignore
# =============================================================================
# This is a PUBLIC showcase repo. Engagement data must NEVER land here.
# Primary defense: all engagement data lives in ~/engagements (outside the repo).
# This file is defense-in-depth in case anything ever gets copied in by mistake.
# =============================================================================

# ── engagement / client data — hard block ────────────────────────────────────
engagements/
loot/
creds/
evidence/
exploits/
report/
scope.md
*.scope

# ── captures, hashes, cred stores, scanner output ────────────────────────────
*.pcap
*.cap
*.hccapx
*.kdbx
*.ntds
*.dit
hashes*
*.nessus
*.gnmap
*.nmap
*.xml          # nmap/burp/scanner exports — review before ever un-ignoring
secrets*
*.creds

# ── secrets / env ─────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
id_rsa*
id_ed25519*

# ── ssh: track only the sanitized config ──────────────────────────────────────
ssh/*
!ssh/config

# ── local-only / generated ────────────────────────────────────────────────────
zsh/local.zsh
core/nvim/lazy-lock.json
*.pre-dotfiles.*
*.log
*.bak

# ── OS noise ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
