# dotfiles-core/.gitignore — Core is config only; never machine state or secrets.
*.log
*.bak
.DS_Store
# machine-specific overrides never sync up to Core
zsh/local.zsh
# generated by `make setup` from scripts/tool-versions.env (repo-local dev toolchain)
mise.local.toml
.env
.env.*
!.env.example
# Claude Code: ignore local/transient session state, but DO track the shared
# Claude-Code-on-the-web setup (the SessionStart hook that provisions the gate
# toolchain + its settings) and the shared maintenance routines (slash commands +
# subagents) so every session — local or remote — has them. settings.local.json
# stays ignored (it's per-machine).
.claude/*
!.claude/hooks/
!.claude/settings.json
!.claude/commands/
!.claude/agents/
.claude/settings.local.json
